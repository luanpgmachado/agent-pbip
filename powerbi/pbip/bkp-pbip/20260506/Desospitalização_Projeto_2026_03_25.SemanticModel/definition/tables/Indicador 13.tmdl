		dataType: dateTime
		formatString: Long Date
		lineageTag: 377f6e39-1d50-4733-9093-5dd022a6cb4a
		summarizeBy: none
		sourceColumn: dt_carga

		variation Variation
			isDefault
			relationship: c91aaf55-c141-4996-b7b0-4ea2f96d819e
			defaultHierarchy: LocalDateTable_bba27d54-b233-48ca-b420-3b9b7ae707b5.'Hierarquia de datas'

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

	partition 'Indicador 13' = m
		mode: import
		source =
				let
				    Fonte = PostgreSQL.Database("192.168.6.2:5432", "prohmdw"),
				    Planilha = Fonte{[Schema="public", Item="fato_desospitalizacao_acuracia_alta"]}[Data],
				    Headers = Planilha,
				
				    ColunasExistentes = Table.ColumnNames(Headers),
				
				    ConverterParaDateTime = (v as any) as nullable datetime =>
				        let
				            Resultado =
				                if v = null then
				                    null
				                else if Value.Is(v, type datetime) then
				                    v
				                else if Value.Is(v, type date) then
				                    DateTime.From(v)
				                else if Value.Is(v, type number) then
				                    try DateTime.From(v) otherwise null
				                else
				                    let
				                        Texto = Text.Trim(Text.From(v)),
				
				                        TentativaNumeroPT = try Number.FromText(Texto, "pt-BR"),
				                        TentativaNumeroUS = try Number.FromText(Texto, "en-US"),
				
				                        TentativaDataHoraBR = try DateTime.FromText(Texto, [Culture = "pt-BR"]),
				                        TentativaDataHoraUS = try DateTime.FromText(Texto, [Culture = "en-US"]),
				
				                        TentativaDataBR = try Date.FromText(Texto, [Culture = "pt-BR"]),
				                        TentativaDataUS = try Date.FromText(Texto, [Culture = "en-US"])
				                    in
				                        if Texto = "" then
				                            null
				                        else if not TentativaNumeroPT[HasError] then
				                            try DateTime.From(TentativaNumeroPT[Value]) otherwise null
				                        else if not TentativaNumeroUS[HasError] then
				                            try DateTime.From(TentativaNumeroUS[Value]) otherwise null
				                        else if not TentativaDataHoraBR[HasError] then
				                            TentativaDataHoraBR[Value]
				                        else if not TentativaDataHoraUS[HasError] then
				                            TentativaDataHoraUS[Value]
				                        else if not TentativaDataBR[HasError] then
				                            DateTime.From(TentativaDataBR[Value])
				                        else if not TentativaDataUS[HasError] then
				                            DateTime.From(TentativaDataUS[Value])
				                        else
				                            null
				        in
				            Resultado,
				
				    ColunasDataHora = {
				        "DT_ENTRADA",
				        "DT_ALTA",
				        "DT_SAIDA_REAL",
				        "DT_PREVISTA_ALTA",
				        "DT_EVENTO_PREVISAO",
				        "DT_ALTA_REAL"
				    },
				
				    ColunasDataHoraExistentes = List.Intersect({ColunasDataHora, ColunasExistentes}),
				
				    DatasAjustadas = Table.TransformColumns(
				        Headers,
				        List.Transform(
				            ColunasDataHoraExistentes,
				            (col) => {col, each ConverterParaDateTime(_), type nullable datetime}
				        )
				    ),
				
				    TiposDesejados = {
				        {"NR_ATENDIMENTO", Int64.Type},
				        {"CD_PACIENTE", type text},
				        {"CD_MEDICO", type text},
				        {"CD_SETOR", Int64.Type},
				        {"PACIENTE", type text},
				        {"DT_ENTRADA", type datetime},
				        {"DT_ALTA", type datetime},
				        {"DT_SAIDA_REAL", type datetime},
				        {"DT_PREVISTA_ALTA", type datetime},
				        {"DT_EVENTO_PREVISAO", type datetime},
				        {"DT_ALTA_REAL", type datetime},
				        {"QT_DIF_DIAS_PREVISTO_REAL", type number},
				        {"FL_ACERTO_EXATO", type text},
				        {"FL_ACERTO_TOLERANCIA", type text},
				        {"INDICADOR_PERCENTUAL_ACURACIA", type number}
				    },
				
				    TiposParaAplicar = List.Select(
				        TiposDesejados,
				        each List.Contains(ColunasExistentes, _{0})
				    ),
				
				    Tipos = Table.TransformColumnTypes(
				        DatasAjustadas,
				        TiposParaAplicar
				    )
				in
				    Tipos

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navegação

