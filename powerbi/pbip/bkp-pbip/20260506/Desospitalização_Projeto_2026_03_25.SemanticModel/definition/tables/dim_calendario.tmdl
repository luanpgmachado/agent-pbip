	partition dim_calendario = calculated
		mode: import
		source =
				VAR _minDate = DATE(2020, 1, 1)
				VAR _maxDate = TODAY() + 365
				VAR _cal = ADDCOLUMNS(
				    CALENDAR(_minDate, _maxDate),
				    "nr_ano", YEAR([Date]),
				    "nr_trimestre", QUARTER([Date]),
				    "nr_mes", MONTH([Date]),
				    "nr_semana_iso", WEEKNUM([Date], 2),
				    "nr_dia", DAY([Date]),
				    "nr_dia_semana", WEEKDAY([Date], 1),
				    "ds_ano", FORMAT([Date], "YYYY"),
				    "ds_ano_trimestre", FORMAT([Date], "YYYY") & "-T" & FORMAT(QUARTER([Date]), "0"),
				    "ds_ano_mes", FORMAT([Date], "YYYY-MM"),
				    "ds_ano_semana", FORMAT([Date], "YYYY") & "-" & FORMAT(WEEKNUM([Date], 2), "00"),
				    "ds_mes", FORMAT([Date], "MMMM"),
				    "ds_dia_semana_extenso", FORMAT([Date], "DDDD"),
				    "ds_data_br", FORMAT([Date], "DD/MM/YYYY"),
				    "ds_data_iso", FORMAT([Date], "YYYY-MM-DD"),
				    "ie_fim_semana", IF(WEEKDAY([Date],1) IN {1,7}, "S", "N"),
				    "ie_hoje", IF([Date] = TODAY(), "S", "N"),
				    "ds_periodo_relativo", IF([Date] < TODAY(), "PASSADO", IF([Date] = TODAY(), "HOJE", "FUTURO"))
				)
				RETURN
				    SELECTCOLUMNS(_cal,
				        "dt_data", [Date],
				        "nr_ano", [nr_ano],
				        "nr_trimestre", [nr_trimestre],
				        "nr_mes", [nr_mes],
				        "nr_semana_iso", [nr_semana_iso],
				        "nr_dia", [nr_dia],
				        "nr_dia_semana", [nr_dia_semana],
				        "ds_ano", [ds_ano],
				        "ds_ano_trimestre", [ds_ano_trimestre],
				        "ds_ano_mes", [ds_ano_mes],
				        "ds_ano_semana", [ds_ano_semana],
				        "ds_mes", [ds_mes],
				        "ds_dia_semana_extenso", [ds_dia_semana_extenso],
				        "ds_data_br", [ds_data_br],
				        "ds_data_iso", [ds_data_iso],
				        "ie_fim_semana", [ie_fim_semana],
				        "ie_hoje", [ie_hoje],
				        "ds_periodo_relativo", [ds_periodo_relativo]
				    )

