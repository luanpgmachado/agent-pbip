			        VAR _nmPessoaFisica3 = SUBSTITUTE ( _nmPessoaFisica2, UNICHAR ( 13 ), " " )
			        VAR _nmPessoaFisica4 = SUBSTITUTE ( _nmPessoaFisica3, UNICHAR ( 10 ), " " )
			        VAR _nmPessoaFisica5 = SUBSTITUTE ( _nmPessoaFisica4, UNICHAR ( 9 ), " " )
			        VAR _nmPessoaFisicaJson = IF ( ISBLANK ( _nmPessoaFisicaTxt ), "null", Q & _nmPessoaFisica5 & Q )
			
			        // --- Escape JSON para CD_ESTABELECIMENTO ---
			        VAR _cdEstabelecimentoTxt = IF ( ISBLANK ( _cdEstabelecimento ), BLANK (), "" & _cdEstabelecimento )
			        VAR _cdEstabelecimento1 = SUBSTITUTE ( _cdEstabelecimentoTxt, BS, BS & BS )
			        VAR _cdEstabelecimento2 = SUBSTITUTE ( _cdEstabelecimento1, Q, BS & Q )
			        VAR _cdEstabelecimento3 = SUBSTITUTE ( _cdEstabelecimento2, UNICHAR ( 13 ), " " )
			        VAR _cdEstabelecimento4 = SUBSTITUTE ( _cdEstabelecimento3, UNICHAR ( 10 ), " " )
			        VAR _cdEstabelecimento5 = SUBSTITUTE ( _cdEstabelecimento4, UNICHAR ( 9 ), " " )
			        VAR _cdEstabelecimentoJson = IF ( ISBLANK ( _cdEstabelecimentoTxt ), "null", Q & _cdEstabelecimento5 & Q )
			
			        // --- Escape JSON para CD_SETOR_ATENDIMENTO ---
			        VAR _cdSetorAtendimentoTxt = IF ( ISBLANK ( _cdSetorAtendimento ), BLANK (), "" & _cdSetorAtendimento )
			        VAR _cdSetorAtendimento1 = SUBSTITUTE ( _cdSetorAtendimentoTxt, BS, BS & BS )
			        VAR _cdSetorAtendimento2 = SUBSTITUTE ( _cdSetorAtendimento1, Q, BS & Q )
			        VAR _cdSetorAtendimento3 = SUBSTITUTE ( _cdSetorAtendimento2, UNICHAR ( 13 ), " " )
			        VAR _cdSetorAtendimento4 = SUBSTITUTE ( _cdSetorAtendimento3, UNICHAR ( 10 ), " " )
			        VAR _cdSetorAtendimento5 = SUBSTITUTE ( _cdSetorAtendimento4, UNICHAR ( 9 ), " " )
			        VAR _cdSetorAtendimentoJson = IF ( ISBLANK ( _cdSetorAtendimentoTxt ), "null", Q & _cdSetorAtendimento5 & Q )
			
			        // --- Escape JSON para CD_CID ---
			        VAR _cdCidTxt = IF ( ISBLANK ( _cdCid ), BLANK (), "" & _cdCid )
			        VAR _cdCid1 = SUBSTITUTE ( _cdCidTxt, BS, BS & BS )
			        VAR _cdCid2 = SUBSTITUTE ( _cdCid1, Q, BS & Q )
			        VAR _cdCid3 = SUBSTITUTE ( _cdCid2, UNICHAR ( 13 ), " " )
			        VAR _cdCid4 = SUBSTITUTE ( _cdCid3, UNICHAR ( 10 ), " " )
			        VAR _cdCid5 = SUBSTITUTE ( _cdCid4, UNICHAR ( 9 ), " " )
			        VAR _cdCidJson = IF ( ISBLANK ( _cdCidTxt ), "null", Q & _cdCid5 & Q )
			
			        // Numeros com ponto decimal para JSON.
