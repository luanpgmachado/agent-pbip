	/// Array Indicador 02 (TAT) — exames concluidos (DT_EVENTO_FINAL preenchido).
	/// Campos (nomes de coluna): DT_PRESCRICAO, CD_ESTABELECIMENTO, CD_SETOR_PACIENTE, CD_DOMINIO, CD_MEDICO, NM_MEDICO, TAT_HORAS.
	measure 'JSON TAT Exames' =
			
			VAR Q = UNICHAR ( 34 )         // Aspas duplas (") para montar chaves/strings JSON.
			VAR BS = "\"                   // Barra invertida (\) usada para escape.
			VAR _maxRows = 1800            // Limite de linhas para proteger performance no HTML.
			
			VAR _base =
			    FILTER (
			        'Indicador 02',
			        // Regra de elegibilidade TAT: só exames com prescrição, conclusão e TAT preenchidos.
			        NOT ( ISBLANK ( 'Indicador 02'[DT_PRESCRICAO] ) ) &&
			        NOT ( ISBLANK ( 'Indicador 02'[DT_EVENTO_FINAL] ) ) &&
			        NOT ( ISBLANK ( 'Indicador 02'[TAT_HORAS] ) )
			    )
			
			VAR _rows =
			    TOPN (
			        _maxRows,
			        _base,
			        // Amostra prioriza registros mais recentes.
			        'Indicador 02'[DT_PRESCRICAO], DESC,
			        'Indicador 02'[NR_PRESCRICAO], DESC
			    )
			
			VAR _json =
			    CONCATENATEX (
			        _rows,
			        // Campos base por linha (sem COALESCE multi-campo).
			        VAR _nrPrescricao = 'Indicador 02'[NR_PRESCRICAO]
			        VAR _dtPrescricao = FORMAT ( 'Indicador 02'[DT_PRESCRICAO], "yyyy-MM-dd" )
			        VAR _cdEstabelecimento = 'Indicador 02'[CD_ESTABELECIMENTO]
			        VAR _cdSetorPaciente = 'Indicador 02'[CD_SETOR_PACIENTE]
			        VAR _cdDominio = 'Indicador 02'[CD_DOMINIO]
			        VAR _cdMedico = 'Indicador 02'[CD_MEDICO]
			        VAR _nmMedico = 'Indicador 02'[NM_MEDICO]
			
			        // --- Escape JSON para CD_ESTABELECIMENTO ---
			        VAR _cdEstabelecimentoTxt = IF ( ISBLANK ( _cdEstabelecimento ), BLANK (), "" & _cdEstabelecimento )
			        VAR _cdEstabelecimento1 = SUBSTITUTE ( _cdEstabelecimentoTxt, BS, BS & BS )   // \ -> \\
			        VAR _cdEstabelecimento2 = SUBSTITUTE ( _cdEstabelecimento1, Q, BS & Q )       // " -> \"
			        VAR _cdEstabelecimento3 = SUBSTITUTE ( _cdEstabelecimento2, UNICHAR ( 13 ), " " ) // CR
			        VAR _cdEstabelecimento4 = SUBSTITUTE ( _cdEstabelecimento3, UNICHAR ( 10 ), " " ) // LF
			        VAR _cdEstabelecimento5 = SUBSTITUTE ( _cdEstabelecimento4, UNICHAR ( 9 ), " " )  // TAB
			        VAR _cdEstabelecimentoJson = IF ( ISBLANK ( _cdEstabelecimentoTxt ), "null", Q & _cdEstabelecimento5 & Q )
			
			        // --- Escape JSON para CD_SETOR_PACIENTE ---
			        VAR _cdSetorPacienteTxt = IF ( ISBLANK ( _cdSetorPaciente ), BLANK (), "" & _cdSetorPaciente )
			        VAR _cdSetorPaciente1 = SUBSTITUTE ( _cdSetorPacienteTxt, BS, BS & BS )
			        VAR _cdSetorPaciente2 = SUBSTITUTE ( _cdSetorPaciente1, Q, BS & Q )
			        VAR _cdSetorPaciente3 = SUBSTITUTE ( _cdSetorPaciente2, UNICHAR ( 13 ), " " )
			        VAR _cdSetorPaciente4 = SUBSTITUTE ( _cdSetorPaciente3, UNICHAR ( 10 ), " " )
			        VAR _cdSetorPaciente5 = SUBSTITUTE ( _cdSetorPaciente4, UNICHAR ( 9 ), " " )
			        VAR _cdSetorPacienteJson = IF ( ISBLANK ( _cdSetorPacienteTxt ), "null", Q & _cdSetorPaciente5 & Q )
			
			        // --- Escape JSON para CD_DOMINIO ---
			        VAR _cdDominioTxt = IF ( ISBLANK ( _cdDominio ), BLANK (), "" & _cdDominio )
			        VAR _cdDominio1 = SUBSTITUTE ( _cdDominioTxt, BS, BS & BS )
			        VAR _cdDominio2 = SUBSTITUTE ( _cdDominio1, Q, BS & Q )
			        VAR _cdDominio3 = SUBSTITUTE ( _cdDominio2, UNICHAR ( 13 ), " " )
			        VAR _cdDominio4 = SUBSTITUTE ( _cdDominio3, UNICHAR ( 10 ), " " )
			        VAR _cdDominio5 = SUBSTITUTE ( _cdDominio4, UNICHAR ( 9 ), " " )
			        VAR _cdDominioJson = IF ( ISBLANK ( _cdDominioTxt ), "null", Q & _cdDominio5 & Q )
			
			        // --- Escape JSON para CD_MEDICO ---
			        VAR _cdMedicoTxt = IF ( ISBLANK ( _cdMedico ), BLANK (), "" & _cdMedico )
			        VAR _cdMedico1 = SUBSTITUTE ( _cdMedicoTxt, BS, BS & BS )
			        VAR _cdMedico2 = SUBSTITUTE ( _cdMedico1, Q, BS & Q )
			        VAR _cdMedico3 = SUBSTITUTE ( _cdMedico2, UNICHAR ( 13 ), " " )
			        VAR _cdMedico4 = SUBSTITUTE ( _cdMedico3, UNICHAR ( 10 ), " " )
			        VAR _cdMedico5 = SUBSTITUTE ( _cdMedico4, UNICHAR ( 9 ), " " )
			        VAR _cdMedicoJson = IF ( ISBLANK ( _cdMedicoTxt ), "null", Q & _cdMedico5 & Q )
			
			        // --- Escape JSON para NM_MEDICO ---
			        VAR _nmMedicoTxt = IF ( ISBLANK ( _nmMedico ), BLANK (), "" & _nmMedico )
			        VAR _nmMedico1 = SUBSTITUTE ( _nmMedicoTxt, BS, BS & BS )
			        VAR _nmMedico2 = SUBSTITUTE ( _nmMedico1, Q, BS & Q )
			        VAR _nmMedico3 = SUBSTITUTE ( _nmMedico2, UNICHAR ( 13 ), " " )
			        VAR _nmMedico4 = SUBSTITUTE ( _nmMedico3, UNICHAR ( 10 ), " " )
			        VAR _nmMedico5 = SUBSTITUTE ( _nmMedico4, UNICHAR ( 9 ), " " )
			        VAR _nmMedicoJson = IF ( ISBLANK ( _nmMedicoTxt ), "null", Q & _nmMedico5 & Q )
			
			        // Numero com ponto decimal para JSON.
			        VAR _tatHoras = SUBSTITUTE ( FORMAT ( 'Indicador 02'[TAT_HORAS], "0.00" ), ",", "." )
			
			        // Monta 1 objeto JSON por linha.
			        RETURN
			            "{" &
			            Q & "DT_PRESCRICAO" & Q & ":" & Q & _dtPrescricao & Q & "," &
			            Q & "NR_PRESCRICAO" & Q & ":" & Q & _nrPrescricao & Q & "," &
			            Q & "CD_ESTABELECIMENTO" & Q & ":" & _cdEstabelecimentoJson & "," &
			            Q & "CD_SETOR_PACIENTE" & Q & ":" & _cdSetorPacienteJson & "," &
			            Q & "CD_DOMINIO" & Q & ":" & _cdDominioJson & "," &
			            Q & "CD_MEDICO" & Q & ":" & _cdMedicoJson & "," &
			            Q & "NM_MEDICO" & Q & ":" & _nmMedicoJson & "," &
			            Q & "TAT_HORAS" & Q & ":" & _tatHoras &
			            "}",
			        "," // Separador entre objetos.
			    )
			
			// Sempre retorna array JSON valido.
			RETURN
			    IF ( LEN ( _json ) = 0, "[]", "[" & _json & "]" )
		displayFolder: HTML
		lineageTag: b2c3d4e5-f6a7-4b8c-9d0e-1f2a3b4c5d6e

	/// Array Indicador 06 (Permanencia) — atendimentos com DT_ENTRADA preenchida.
	/// Campos (nomes de coluna): DT_ENTRADA, NR_ATENDIMENTO, NM_PESSOA_FISICA, CD_ESTABELECIMENTO, CD_SETOR_ATENDIMENTO, CD_CID, QT_DIA_PERMANENCIA, MEDIA_QT_DIA_PERMANENCIA_SETOR_CID.
