			        VAR _nrAtendimento = 'Indicador 06'[NR_ATENDIMENTO]
			        VAR _nmPessoaFisica = 'Indicador 06'[NM_PESSOA_FISICA]
			        VAR _cdEstabelecimento = 'Indicador 06'[CD_ESTABELECIMENTO]
			        VAR _cdSetorAtendimento = 'Indicador 06'[CD_SETOR_ATENDIMENTO]
			        VAR _cdCid = 'Indicador 06'[CD_CID]
			        VAR _qtDiaPermanencia = 'Indicador 06'[QT_DIA_PERMANENCIA]
			        VAR _mediaQtDiaPermanenciaSetorCid = 'Indicador 06'[MEDIA_QT_DIA_PERMANENCIA_SETOR_CID]
			
			        // --- Escape JSON para NM_PESSOA_FISICA ---
