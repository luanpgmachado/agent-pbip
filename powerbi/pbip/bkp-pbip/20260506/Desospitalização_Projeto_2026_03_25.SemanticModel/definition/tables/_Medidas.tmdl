	/// Array Indicador 13 (Acuracia Alta) — atendimentos com DT_ALTA_REAL preenchida.
	/// Campos (nomes de coluna): NR_ATENDIMENTO, CD_PACIENTE, DT_PREVISTA_ALTA, DT_ALTA_REAL, CD_SETOR, CD_MEDICO,
	/// FL_ACERTO_TOLERANCIA, INDICADOR_PERCENTUAL_ACURACIA, QT_DIF_DIAS_PREVISTO_REAL, ERRO_ABSOLUTO_DIAS, TIPO_ERRO_PREVISAO, NIVEL_SEVERIDADE_ERRO.
	measure 'JSON Acuracia Alta' =
			VAR Q = UNICHAR ( 34 )         // Aspas duplas (") para montar chaves/strings JSON.
			VAR BS = "\"                   // Barra invertida (\) usada para escape.
			VAR _maxRows = 1800            // Limite de linhas para proteger performance no HTML.
			
			VAR _base =
			    FILTER (
			        'Indicador 13',
			        // Regra de elegibilidade: atendimentos com data de alta real.
			        NOT ( ISBLANK ( 'Indicador 13'[DT_ALTA_REAL] ) )
			    )
			
			VAR _baseComCampos =
			    ADDCOLUMNS (
			        _base,
			        "__erro_absoluto_dias",
			            IF (
			                ISBLANK ( 'Indicador 13'[QT_DIF_DIAS_PREVISTO_REAL] ),
			                -1,
			                ABS ( 'Indicador 13'[QT_DIF_DIAS_PREVISTO_REAL] )
			            )
			    )
			
			VAR _rows =
			    TOPN (
			        _maxRows,
			        _baseComCampos,
			        // Criticidade: maior erro absoluto primeiro.
			        [__erro_absoluto_dias], DESC,
			        'Indicador 13'[DT_ALTA_REAL], DESC,
			        'Indicador 13'[NR_ATENDIMENTO], DESC
			    )
			
			VAR _json =
			    CONCATENATEX (
			        _rows,
			        // Campos base por linha (sem COALESCE multi-campo).
			        VAR _nrAtendimento = 'Indicador 13'[NR_ATENDIMENTO]
			        VAR _cdPaciente = 'Indicador 13'[CD_PACIENTE]
			        VAR _dtPrevistaAltaRaw = 'Indicador 13'[DT_PREVISTA_ALTA]
			        VAR _dtPrevistaAlta =
			            IF ( ISBLANK ( _dtPrevistaAltaRaw ), BLANK (), FORMAT ( _dtPrevistaAltaRaw, "yyyy-MM-dd" ) )
			        VAR _dtAltaReal = FORMAT ( 'Indicador 13'[DT_ALTA_REAL], "yyyy-MM-dd" )
			        VAR _cdSetor = 'Indicador 13'[CD_SETOR]
			        VAR _cdMedico = 'Indicador 13'[CD_MEDICO]
			        VAR _flAcertoTolerancia = 'Indicador 13'[FL_ACERTO_TOLERANCIA]
			        VAR _indicadorPercentualAcuracia = 'Indicador 13'[INDICADOR_PERCENTUAL_ACURACIA]
			        VAR _qtDifDiasPrevistoReal = 'Indicador 13'[QT_DIF_DIAS_PREVISTO_REAL]
			        VAR _erroAbsolutoDias =
			            IF ( ISBLANK ( _qtDifDiasPrevistoReal ), BLANK (), ABS ( _qtDifDiasPrevistoReal ) )
			        VAR _tipoErroPrevisao =
			            IF (
			                ISBLANK ( _qtDifDiasPrevistoReal ),
			                BLANK (),
			                IF (
			                    _qtDifDiasPrevistoReal < 0,
			                    "antecipada",
			                    IF ( _qtDifDiasPrevistoReal = 0, "exata", "atrasada" )
			                )
			            )
			        // Faixas default operacionais (suposicao de severidade para o indicador 13).
			        VAR _nivelSeveridadeErro =
			            IF (
			                ISBLANK ( _erroAbsolutoDias ),
			                BLANK (),
			                IF (
			                    _erroAbsolutoDias < 1,
			                    "leve",
			                    IF ( _erroAbsolutoDias < 3, "moderado", "grave" )
			                )
			            )
			
			        // --- Escape JSON para CD_SETOR ---
			        VAR _cdSetorTxt = IF ( ISBLANK ( _cdSetor ), BLANK (), "" & _cdSetor )
			        VAR _cdSetor1 = SUBSTITUTE ( _cdSetorTxt, BS, BS & BS )
			        VAR _cdSetor2 = SUBSTITUTE ( _cdSetor1, Q, BS & Q )
			        VAR _cdSetor3 = SUBSTITUTE ( _cdSetor2, UNICHAR ( 13 ), " " )
			        VAR _cdSetor4 = SUBSTITUTE ( _cdSetor3, UNICHAR ( 10 ), " " )
			        VAR _cdSetor5 = SUBSTITUTE ( _cdSetor4, UNICHAR ( 9 ), " " )
			        VAR _cdSetorJson = IF ( ISBLANK ( _cdSetorTxt ), "null", Q & _cdSetor5 & Q )
			
			        // --- Escape JSON para CD_MEDICO ---
			        VAR _cdMedicoTxt = IF ( ISBLANK ( _cdMedico ), BLANK (), "" & _cdMedico )
			        VAR _cdMedico1 = SUBSTITUTE ( _cdMedicoTxt, BS, BS & BS )
			        VAR _cdMedico2 = SUBSTITUTE ( _cdMedico1, Q, BS & Q )
			        VAR _cdMedico3 = SUBSTITUTE ( _cdMedico2, UNICHAR ( 13 ), " " )
			        VAR _cdMedico4 = SUBSTITUTE ( _cdMedico3, UNICHAR ( 10 ), " " )
			        VAR _cdMedico5 = SUBSTITUTE ( _cdMedico4, UNICHAR ( 9 ), " " )
			        VAR _cdMedicoJson = IF ( ISBLANK ( _cdMedicoTxt ), "null", Q & _cdMedico5 & Q )
			
			        // Chaves numericas.
			        VAR _nrAtendimentoJson =
			            IF ( ISBLANK ( _nrAtendimento ), "null", FORMAT ( _nrAtendimento, "0" ) )
			        VAR _cdPacienteJson =
			            IF ( ISBLANK ( _cdPaciente ), "null", FORMAT ( _cdPaciente, "0" ) )
			
			        // Datas.
			        VAR _dtPrevistaAltaJson =
			            IF ( ISBLANK ( _dtPrevistaAlta ), "null", Q & _dtPrevistaAlta & Q )
			
			        // Numeros com ponto decimal para JSON.
			        VAR _flAcertoToleranciaJson =
			            IF ( ISBLANK ( _flAcertoTolerancia ), "null", Q & _flAcertoTolerancia & Q )
			        VAR _indicadorPercentualAcuraciaJson =
			            IF (
			                ISBLANK ( _indicadorPercentualAcuracia ),
			                "null",
			                SUBSTITUTE ( FORMAT ( _indicadorPercentualAcuracia, "0.00" ), ",", "." )
			            )
			        VAR _qtDifDiasPrevistoRealJson =
			            IF (
			                ISBLANK ( _qtDifDiasPrevistoReal ),
			                "null",
			                SUBSTITUTE ( FORMAT ( _qtDifDiasPrevistoReal, "0.00" ), ",", "." )
			            )
			        VAR _erroAbsolutoDiasJson =
			            IF (
			                ISBLANK ( _erroAbsolutoDias ),
			                "null",
			                SUBSTITUTE ( FORMAT ( _erroAbsolutoDias, "0.00" ), ",", "." )
			            )
			        VAR _tipoErroPrevisaoJson =
			            IF ( ISBLANK ( _tipoErroPrevisao ), "null", Q & _tipoErroPrevisao & Q )
			        VAR _nivelSeveridadeErroJson =
			            IF ( ISBLANK ( _nivelSeveridadeErro ), "null", Q & _nivelSeveridadeErro & Q )
			        RETURN
			            "{" &
			            Q & "NR_ATENDIMENTO" & Q & ":" & _nrAtendimentoJson & "," &
			            Q & "ID_DRILL_DOWN" & Q & ":" & _nrAtendimentoJson & "," &
			            Q & "CD_PACIENTE" & Q & ":" & _cdPacienteJson & "," &
			            Q & "DT_PREVISTA_ALTA" & Q & ":" & _dtPrevistaAltaJson & "," &
			            Q & "DT_ALTA_REAL" & Q & ":" & Q & _dtAltaReal & Q & "," &
			            Q & "CD_SETOR" & Q & ":" & _cdSetorJson & "," &
			            Q & "CD_MEDICO" & Q & ":" & _cdMedicoJson & "," &
			            Q & "FL_ACERTO_TOLERANCIA" & Q & ":" & _flAcertoToleranciaJson & "," &
			            Q & "INDICADOR_PERCENTUAL_ACURACIA" & Q & ":" & _indicadorPercentualAcuraciaJson & "," &
			            Q & "QT_DIF_DIAS_PREVISTO_REAL" & Q & ":" & _qtDifDiasPrevistoRealJson & "," &
			            Q & "ERRO_ABSOLUTO_DIAS" & Q & ":" & _erroAbsolutoDiasJson & "," &
			            Q & "TIPO_ERRO_PREVISAO" & Q & ":" & _tipoErroPrevisaoJson & "," &
			            Q & "NIVEL_SEVERIDADE_ERRO" & Q & ":" & _nivelSeveridadeErroJson &
			            "}",
			        "," // Separador entre objetos.
			    )
			
			// Sempre retorna array JSON valido.
			RETURN
			    IF ( LEN ( _json ) = 0, "[]", "[" & _json & "]" )
		displayFolder: HTML
		lineageTag: d4e5f6a7-b8c9-4d0e-1f2a-3b4c5d6e7f8a

	/// Array Indicador 14 (Readmissao) — altas com DT_SAIDA_ORIGEM preenchida.
	/// Campos (nomes de coluna): NR_ATENDIMENTO_ORIGEM, NR_ATENDIMENTO_RETORNO, NM_PACIENTE, DT_SAIDA_ORIGEM,
	/// DT_ENTRADA_RETORNO, QT_DIAS_ATE_READMISSAO, DS_FAIXA_READMISSAO, TIPO_LINHA, NIVEL_RISCO_READMISSAO, NIVEL_SEVERIDADE_READMISSAO,
	/// CD_ESTABELECIMENTO_ORIGEM, DS_SETOR_ATENDIMENTO_RETORNO, NM_MEDICO_RETORNO, IE_DENOMINADOR_7_DIAS,
	/// IE_READMISSAO_7_DIAS, IE_DENOMINADOR_30_DIAS, IE_READMISSAO_30_DIAS_TOTAL.
	measure 'JSON Readmissao' =
			VAR Q = UNICHAR ( 34 )         // Aspas duplas (") para montar chaves/strings JSON.
			VAR BS = "\"                   // Barra invertida (\) usada para escape.
			VAR _maxRows = 1800            // Limite de linhas para proteger performance no HTML.
			
			VAR _base =
			    FILTER (
			        'Indicador 14',
			        // Regra de elegibilidade: altas com data de saida de origem.
			        NOT ( ISBLANK ( 'Indicador 14'[DT_SAIDA_ORIGEM] ) )
			    )
			
			VAR _baseComCampos =
			    ADDCOLUMNS (
			        _base,
			        "__sort_dias_readmissao",
			            IF (
			                ISBLANK ( 'Indicador 14'[QT_DIAS_ATE_READMISSAO] ),
			                999999,
			                'Indicador 14'[QT_DIAS_ATE_READMISSAO]
			            )
			    )
			
			VAR _rows =
			    TOPN (
			        _maxRows,
			        _baseComCampos,
			        // Criticidade: menor tempo ate readmissao primeiro (nulos ao final).
			        [__sort_dias_readmissao], ASC,
			        'Indicador 14'[DT_SAIDA_ORIGEM], DESC,
			        'Indicador 14'[NR_ATENDIMENTO_ORIGEM], DESC
			    )
			
			VAR _json =
			    CONCATENATEX (
			        _rows,
			        // Campos base por linha (sem COALESCE multi-campo).
			        VAR _nrAtendimentoOrigem = 'Indicador 14'[NR_ATENDIMENTO_ORIGEM]
			        VAR _nrAtendimentoRetorno = 'Indicador 14'[NR_ATENDIMENTO_RETORNO]
			        VAR _nmPaciente = 'Indicador 14'[NM_PACIENTE]
			        VAR _dtSaidaOrigem = FORMAT ( 'Indicador 14'[DT_SAIDA_ORIGEM], "yyyy-MM-dd" )
			        VAR _dtEntradaRetornoRaw = 'Indicador 14'[DT_ENTRADA_RETORNO]
			        VAR _dtEntradaRetorno =
			            IF ( ISBLANK ( _dtEntradaRetornoRaw ), BLANK (), FORMAT ( _dtEntradaRetornoRaw, "yyyy-MM-dd" ) )
			        VAR _qtDiasAteReadmissao = 'Indicador 14'[QT_DIAS_ATE_READMISSAO]
			        VAR _dsFaixaReadmissao = 'Indicador 14'[DS_FAIXA_READMISSAO]
			        VAR _cdEstabelecimentoOrigem = 'Indicador 14'[CD_ESTABELECIMENTO_ORIGEM]
			        VAR _dsSetorAtendimentoRetorno = 'Indicador 14'[DS_SETOR_ATENDIMENTO_RETORNO]
			        VAR _nmMedicoRetorno = 'Indicador 14'[NM_MEDICO_RETORNO]
			        VAR _ieDenominador7Dias = 'Indicador 14'[IE_DENOMINADOR_7_DIAS]
			        VAR _ieReadmissao7Dias = 'Indicador 14'[IE_READMISSAO_7_DIAS]
			        VAR _ieDenominador30Dias = 'Indicador 14'[IE_DENOMINADOR_30_DIAS]
			        VAR _ieReadmissao30DiasTotal = 'Indicador 14'[IE_READMISSAO_30_DIAS_TOTAL]
			        VAR _temReadmissao7Dias = _ieReadmissao7Dias = "S"
			        VAR _temReadmissao30Dias = _ieReadmissao30DiasTotal = "S"
			        VAR _tipoLinha =
			            IF (
			                _temReadmissao7Dias,
			                "readmissao_7d",
			                IF ( _temReadmissao30Dias, "readmissao_30d", "base" )
			            )
			        VAR _nivelRiscoReadmissao =
			            IF (
			                NOT ( _temReadmissao7Dias || _temReadmissao30Dias ),
			                "normal",
			                IF (
			                    ISBLANK ( _qtDiasAteReadmissao ),
			                    "normal",
			                    IF (
			                        _qtDiasAteReadmissao <= 3,
			                        "critico",
			                        IF ( _qtDiasAteReadmissao <= 7, "alerta", "normal" )
			                    )
			                )
			            )
			        VAR _nivelSeveridadeReadmissao =
			            IF (
			                _nivelRiscoReadmissao = "critico",
			                "grave",
			                IF ( _nivelRiscoReadmissao = "alerta", "moderado", "leve" )
			            )
			
			        // --- Escape JSON para NM_PACIENTE ---
			        VAR _nmPacienteTxt = IF ( ISBLANK ( _nmPaciente ), BLANK (), "" & _nmPaciente )
			        VAR _nmPaciente1 = SUBSTITUTE ( _nmPacienteTxt, BS, BS & BS )
			        VAR _nmPaciente2 = SUBSTITUTE ( _nmPaciente1, Q, BS & Q )
			        VAR _nmPaciente3 = SUBSTITUTE ( _nmPaciente2, UNICHAR ( 13 ), " " )
			        VAR _nmPaciente4 = SUBSTITUTE ( _nmPaciente3, UNICHAR ( 10 ), " " )
			        VAR _nmPaciente5 = SUBSTITUTE ( _nmPaciente4, UNICHAR ( 9 ), " " )
			        VAR _nmPacienteJson = IF ( ISBLANK ( _nmPacienteTxt ), "null", Q & _nmPaciente5 & Q )
			
			        // --- Escape JSON para CD_ESTABELECIMENTO_ORIGEM ---
			        VAR _cdEstabelecimentoOrigemTxt = IF ( ISBLANK ( _cdEstabelecimentoOrigem ), BLANK (), "" & _cdEstabelecimentoOrigem )
			        VAR _cdEstabelecimentoOrigem1 = SUBSTITUTE ( _cdEstabelecimentoOrigemTxt, BS, BS & BS )
			        VAR _cdEstabelecimentoOrigem2 = SUBSTITUTE ( _cdEstabelecimentoOrigem1, Q, BS & Q )
			        VAR _cdEstabelecimentoOrigem3 = SUBSTITUTE ( _cdEstabelecimentoOrigem2, UNICHAR ( 13 ), " " )
			        VAR _cdEstabelecimentoOrigem4 = SUBSTITUTE ( _cdEstabelecimentoOrigem3, UNICHAR ( 10 ), " " )
			        VAR _cdEstabelecimentoOrigem5 = SUBSTITUTE ( _cdEstabelecimentoOrigem4, UNICHAR ( 9 ), " " )
			        VAR _cdEstabelecimentoOrigemJson = IF ( ISBLANK ( _cdEstabelecimentoOrigemTxt ), "null", Q & _cdEstabelecimentoOrigem5 & Q )
			
			        // --- Escape JSON para DS_SETOR_ATENDIMENTO_RETORNO ---
			        VAR _dsSetorAtendimentoRetornoTxt = IF ( ISBLANK ( _dsSetorAtendimentoRetorno ), BLANK (), "" & _dsSetorAtendimentoRetorno )
			        VAR _dsSetorAtendimentoRetorno1 = SUBSTITUTE ( _dsSetorAtendimentoRetornoTxt, BS, BS & BS )
			        VAR _dsSetorAtendimentoRetorno2 = SUBSTITUTE ( _dsSetorAtendimentoRetorno1, Q, BS & Q )
			        VAR _dsSetorAtendimentoRetorno3 = SUBSTITUTE ( _dsSetorAtendimentoRetorno2, UNICHAR ( 13 ), " " )
			        VAR _dsSetorAtendimentoRetorno4 = SUBSTITUTE ( _dsSetorAtendimentoRetorno3, UNICHAR ( 10 ), " " )
			        VAR _dsSetorAtendimentoRetorno5 = SUBSTITUTE ( _dsSetorAtendimentoRetorno4, UNICHAR ( 9 ), " " )
			        VAR _dsSetorAtendimentoRetornoJson =
			            IF ( ISBLANK ( _dsSetorAtendimentoRetornoTxt ), "null", Q & _dsSetorAtendimentoRetorno5 & Q )
			
			        // --- Escape JSON para DS_FAIXA_READMISSAO ---
			        VAR _dsFaixaReadmissaoTxt = IF ( ISBLANK ( _dsFaixaReadmissao ), BLANK (), "" & _dsFaixaReadmissao )
			        VAR _dsFaixaReadmissao1 = SUBSTITUTE ( _dsFaixaReadmissaoTxt, BS, BS & BS )
			        VAR _dsFaixaReadmissao2 = SUBSTITUTE ( _dsFaixaReadmissao1, Q, BS & Q )
			        VAR _dsFaixaReadmissao3 = SUBSTITUTE ( _dsFaixaReadmissao2, UNICHAR ( 13 ), " " )
			        VAR _dsFaixaReadmissao4 = SUBSTITUTE ( _dsFaixaReadmissao3, UNICHAR ( 10 ), " " )
			        VAR _dsFaixaReadmissao5 = SUBSTITUTE ( _dsFaixaReadmissao4, UNICHAR ( 9 ), " " )
			        VAR _dsFaixaReadmissaoJson =
			            IF ( ISBLANK ( _dsFaixaReadmissaoTxt ), "null", Q & _dsFaixaReadmissao5 & Q )
			
			        // --- Escape JSON para NM_MEDICO_RETORNO ---
			        VAR _nmMedicoRetornoTxt = IF ( ISBLANK ( _nmMedicoRetorno ), BLANK (), "" & _nmMedicoRetorno )
			        VAR _nmMedicoRetorno1 = SUBSTITUTE ( _nmMedicoRetornoTxt, BS, BS & BS )
			        VAR _nmMedicoRetorno2 = SUBSTITUTE ( _nmMedicoRetorno1, Q, BS & Q )
			        VAR _nmMedicoRetorno3 = SUBSTITUTE ( _nmMedicoRetorno2, UNICHAR ( 13 ), " " )
			        VAR _nmMedicoRetorno4 = SUBSTITUTE ( _nmMedicoRetorno3, UNICHAR ( 10 ), " " )
			        VAR _nmMedicoRetorno5 = SUBSTITUTE ( _nmMedicoRetorno4, UNICHAR ( 9 ), " " )
			        VAR _nmMedicoRetornoJson = IF ( ISBLANK ( _nmMedicoRetornoTxt ), "null", Q & _nmMedicoRetorno5 & Q )
			
			        // Chaves numericas.
			        VAR _nrAtendimentoOrigemJson =
			            IF ( ISBLANK ( _nrAtendimentoOrigem ), "null", FORMAT ( _nrAtendimentoOrigem, "0" ) )
			        VAR _nrAtendimentoRetornoJson =
			            IF ( ISBLANK ( _nrAtendimentoRetorno ), "null", FORMAT ( _nrAtendimentoRetorno, "0" ) )
			
			        // Campos derivados.
			        VAR _dtEntradaRetornoJson =
			            IF ( ISBLANK ( _dtEntradaRetorno ), "null", Q & _dtEntradaRetorno & Q )
			        VAR _qtDiasAteReadmissaoJson =
			            IF (
			                ISBLANK ( _qtDiasAteReadmissao ),
			                "null",
			                SUBSTITUTE ( FORMAT ( _qtDiasAteReadmissao, "0.00" ), ",", "." )
			            )
			        VAR _tipoLinhaJson = Q & _tipoLinha & Q
			        VAR _nivelRiscoReadmissaoJson = Q & _nivelRiscoReadmissao & Q
			        VAR _nivelSeveridadeReadmissaoJson = Q & _nivelSeveridadeReadmissao & Q
			
			        // Flags S/N em formato string JSON.
			        VAR _ieDenominador7DiasJson = IF ( ISBLANK ( _ieDenominador7Dias ), "null", Q & _ieDenominador7Dias & Q )
			        VAR _ieReadmissao7DiasJson = IF ( ISBLANK ( _ieReadmissao7Dias ), "null", Q & _ieReadmissao7Dias & Q )
			        VAR _ieDenominador30DiasJson = IF ( ISBLANK ( _ieDenominador30Dias ), "null", Q & _ieDenominador30Dias & Q )
			        VAR _ieReadmissao30DiasTotalJson =
			            IF ( ISBLANK ( _ieReadmissao30DiasTotal ), "null", Q & _ieReadmissao30DiasTotal & Q )
			        RETURN
			            "{" &
			            Q & "NR_ATENDIMENTO_ORIGEM" & Q & ":" & _nrAtendimentoOrigemJson & "," &
			            Q & "ID_RASTREABILIDADE_ORIGEM" & Q & ":" & _nrAtendimentoOrigemJson & "," &
			            Q & "NR_ATENDIMENTO_RETORNO" & Q & ":" & _nrAtendimentoRetornoJson & "," &
			            Q & "NM_PACIENTE" & Q & ":" & _nmPacienteJson & "," &
			            Q & "DT_SAIDA_ORIGEM" & Q & ":" & Q & _dtSaidaOrigem & Q & "," &
			            Q & "DT_ENTRADA_RETORNO" & Q & ":" & _dtEntradaRetornoJson & "," &
			            Q & "QT_DIAS_ATE_READMISSAO" & Q & ":" & _qtDiasAteReadmissaoJson & "," &
			            Q & "DS_FAIXA_READMISSAO" & Q & ":" & _dsFaixaReadmissaoJson & "," &
			            Q & "TIPO_LINHA" & Q & ":" & _tipoLinhaJson & "," &
			            Q & "NIVEL_RISCO_READMISSAO" & Q & ":" & _nivelRiscoReadmissaoJson & "," &
			            Q & "NIVEL_SEVERIDADE_READMISSAO" & Q & ":" & _nivelSeveridadeReadmissaoJson & "," &
			            Q & "CD_ESTABELECIMENTO_ORIGEM" & Q & ":" & _cdEstabelecimentoOrigemJson & "," &
			            Q & "DS_SETOR_ATENDIMENTO_RETORNO" & Q & ":" & _dsSetorAtendimentoRetornoJson & "," &
			            Q & "NM_MEDICO_RETORNO" & Q & ":" & _nmMedicoRetornoJson & "," &
			            Q & "IE_DENOMINADOR_7_DIAS" & Q & ":" & _ieDenominador7DiasJson & "," &
			            Q & "IE_READMISSAO_7_DIAS" & Q & ":" & _ieReadmissao7DiasJson & "," &
			            Q & "IE_DENOMINADOR_30_DIAS" & Q & ":" & _ieDenominador30DiasJson & "," &
			            Q & "IE_READMISSAO_30_DIAS_TOTAL" & Q & ":" & _ieReadmissao30DiasTotalJson &
			            "}",
			        "," // Separador entre objetos.
			    )
			
			// Sempre retorna array JSON valido.
			RETURN
			    IF ( LEN ( _json ) = 0, "[]", "[" & _json & "]" )
		displayFolder: HTML
		lineageTag: e5f6a7b8-c9d0-4e1f-2a3b-4c5d6e7f8a9b

	/// Array Indicador 15 (Retorno UTI 48h) — eventos com DT_ENTRADA_RETORNO_UTI preenchida.
	/// Campos (nomes de coluna): NR_ATENDIMENTO, NM_PACIENTE, DT_SAIDA_UTI, DT_ENTRADA_RETORNO_UTI, QT_HORAS_ATE_RETORNO_UTI,
	/// FAIXA_RISCO_RETORNO_UTI, NIVEL_SEVERIDADE_RETORNO_UTI, CD_ESTABELECIMENTO, CD_SETOR_ATENDIMENTO, CD_MEDICO,
	/// IE_READMISSAO_UTI_48H.
	measure 'JSON Retorno UTI' =
			VAR Q = UNICHAR ( 34 )         // Aspas duplas (") para montar chaves/strings JSON.
			VAR BS = "\"                   // Barra invertida (\) usada para escape.
			VAR _maxRows = 1800            // Limite de linhas para proteger performance no HTML.
			
			VAR _base =
			    FILTER (
			        'Indicador 15',
			        // Regra de elegibilidade: eventos com data de entrada no retorno UTI.
			        NOT ( ISBLANK ( 'Indicador 15'[DT_ENTRADA_RETORNO_UTI] ) )
			    )
			
			VAR _baseComCampos =
			    ADDCOLUMNS (
			        _base,
			        "__sort_horas_retorno_uti",
			            IF (
			                ISBLANK ( 'Indicador 15'[QT_HORAS_ATE_RETORNO_UTI] ),
			                999999,
			                'Indicador 15'[QT_HORAS_ATE_RETORNO_UTI]
			            )
			    )
			
			VAR _rows =
			    TOPN (
			        _maxRows,
			        _baseComCampos,
			        // Criticidade: menor tempo ate retorno primeiro.
			        [__sort_horas_retorno_uti], ASC,
			        'Indicador 15'[DT_ENTRADA_RETORNO_UTI], DESC,
			        'Indicador 15'[NR_ATENDIMENTO], DESC
			    )
			
			VAR _json =
			    CONCATENATEX (
			        _rows,
			        // Campos base por linha (sem COALESCE multi-campo).
			        VAR _nrAtendimento = 'Indicador 15'[NR_ATENDIMENTO]
			        VAR _nmPaciente = 'Indicador 15'[NM_PACIENTE]
			        VAR _dtSaidaUtiRaw = 'Indicador 15'[DT_SAIDA_UTI]
			        VAR _dtSaidaUti =
			            IF ( ISBLANK ( _dtSaidaUtiRaw ), BLANK (), FORMAT ( _dtSaidaUtiRaw, "yyyy-MM-dd" ) )
			        VAR _dtEntradaRetornoUti = FORMAT ( 'Indicador 15'[DT_ENTRADA_RETORNO_UTI], "yyyy-MM-dd" )
			        VAR _cdEstabelecimento = 'Indicador 15'[CD_ESTABELECIMENTO]
			        VAR _cdSetorAtendimento = 'Indicador 15'[CD_SETOR_ATENDIMENTO]
			        VAR _cdMedico = 'Indicador 15'[CD_MEDICO]
			        VAR _ieReadmissaoUti48h = 'Indicador 15'[IE_READMISSAO_UTI_48H]
			        VAR _qtHorasAteRetornoUti = 'Indicador 15'[QT_HORAS_ATE_RETORNO_UTI]
			        VAR _faixaRiscoRetornoUti =
			            IF (
			                ISBLANK ( _qtHorasAteRetornoUti ),
			                BLANK (),
			                IF (
			                    _qtHorasAteRetornoUti < 12,
			                    "altamente_critico",
			                    IF ( _qtHorasAteRetornoUti < 24, "critico", "alerta" )
			                )
			            )
			        VAR _nivelSeveridadeRetornoUti =
			            IF (
			                _faixaRiscoRetornoUti = "altamente_critico" || _faixaRiscoRetornoUti = "critico",
			                "grave",
			                IF ( _faixaRiscoRetornoUti = "alerta", "moderado", "leve" )
			            )
			
			        // --- Escape JSON para NM_PACIENTE ---
			        VAR _nmPacienteTxt = IF ( ISBLANK ( _nmPaciente ), BLANK (), "" & _nmPaciente )
			        VAR _nmPaciente1 = SUBSTITUTE ( _nmPacienteTxt, BS, BS & BS )
			        VAR _nmPaciente2 = SUBSTITUTE ( _nmPaciente1, Q, BS & Q )
			        VAR _nmPaciente3 = SUBSTITUTE ( _nmPaciente2, UNICHAR ( 13 ), " " )
			        VAR _nmPaciente4 = SUBSTITUTE ( _nmPaciente3, UNICHAR ( 10 ), " " )
			        VAR _nmPaciente5 = SUBSTITUTE ( _nmPaciente4, UNICHAR ( 9 ), " " )
			        VAR _nmPacienteJson = IF ( ISBLANK ( _nmPacienteTxt ), "null", Q & _nmPaciente5 & Q )
			
			        // --- Escape JSON para CD_ESTABELECIMENTO ---
			        VAR _cdEstabelecimentoTxt = IF ( ISBLANK ( _cdEstabelecimento ), BLANK (), "" & _cdEstabelecimento )
			        VAR _cdEstabelecimento1 = SUBSTITUTE ( _cdEstabelecimentoTxt, BS, BS & BS )
			        VAR _cdEstabelecimento2 = SUBSTITUTE ( _cdEstabelecimento1, Q, BS & Q )
			        VAR _cdEstabelecimento3 = SUBSTITUTE ( _cdEstabelecimento2, UNICHAR ( 13 ), " " )
			        VAR _cdEstabelecimento4 = SUBSTITUTE ( _cdEstabelecimento3, UNICHAR ( 10 ), " " )
			        VAR _cdEstabelecimento5 = SUBSTITUTE ( _cdEstabelecimento4, UNICHAR ( 9 ), " " )
			        VAR _cdEstabelecimentoJson = IF ( ISBLANK ( _cdEstabelecimentoTxt ), "null", Q & _cdEstabelecimento5 & Q )
			
			        // --- Escape JSON para CD_SETOR_ATENDIMENTO ---
			        VAR _cdSetorAtendimentoTxt = IF ( ISBLANK ( _cdSetorAtendimento ), BLANK (), "" & _cdSetorAtendimento )
			        VAR _cdSetorAtendimento1 = SUBSTITUTE ( _cdSetorAtendimentoTxt, BS, BS & BS )
			        VAR _cdSetorAtendimento2 = SUBSTITUTE ( _cdSetorAtendimento1, Q, BS & Q )
			        VAR _cdSetorAtendimento3 = SUBSTITUTE ( _cdSetorAtendimento2, UNICHAR ( 13 ), " " )
			        VAR _cdSetorAtendimento4 = SUBSTITUTE ( _cdSetorAtendimento3, UNICHAR ( 10 ), " " )
			        VAR _cdSetorAtendimento5 = SUBSTITUTE ( _cdSetorAtendimento4, UNICHAR ( 9 ), " " )
			        VAR _cdSetorAtendimentoJson = IF ( ISBLANK ( _cdSetorAtendimentoTxt ), "null", Q & _cdSetorAtendimento5 & Q )
			
			        // --- Escape JSON para CD_MEDICO ---
			        VAR _cdMedicoTxt = IF ( ISBLANK ( _cdMedico ), BLANK (), "" & _cdMedico )
			        VAR _cdMedico1 = SUBSTITUTE ( _cdMedicoTxt, BS, BS & BS )
			        VAR _cdMedico2 = SUBSTITUTE ( _cdMedico1, Q, BS & Q )
			        VAR _cdMedico3 = SUBSTITUTE ( _cdMedico2, UNICHAR ( 13 ), " " )
			        VAR _cdMedico4 = SUBSTITUTE ( _cdMedico3, UNICHAR ( 10 ), " " )
			        VAR _cdMedico5 = SUBSTITUTE ( _cdMedico4, UNICHAR ( 9 ), " " )
			        VAR _cdMedicoJson = IF ( ISBLANK ( _cdMedicoTxt ), "null", Q & _cdMedico5 & Q )
			
			        // Chave numerica.
			        VAR _nrAtendimentoJson =
			            IF ( ISBLANK ( _nrAtendimento ), "null", FORMAT ( _nrAtendimento, "0" ) )
			
			        // Datas.
			        VAR _dtSaidaUtiJson =
			            IF ( ISBLANK ( _dtSaidaUti ), "null", Q & _dtSaidaUti & Q )
			
			        // Flag S/N e valor numerico para JSON.
			        VAR _ieReadmissaoUti48hJson =
			            IF ( ISBLANK ( _ieReadmissaoUti48h ), "null", Q & _ieReadmissaoUti48h & Q )
			        VAR _qtHorasAteRetornoUtiJson =
			            IF ( ISBLANK ( _qtHorasAteRetornoUti ), "null", SUBSTITUTE ( FORMAT ( _qtHorasAteRetornoUti, "0.00" ), ",", "." ) )
			        VAR _faixaRiscoRetornoUtiJson =
			            IF ( ISBLANK ( _faixaRiscoRetornoUti ), "null", Q & _faixaRiscoRetornoUti & Q )
			        VAR _nivelSeveridadeRetornoUtiJson =
			            IF ( ISBLANK ( _faixaRiscoRetornoUti ), "null", Q & _nivelSeveridadeRetornoUti & Q )
			        RETURN
			            "{" &
			            Q & "NR_ATENDIMENTO" & Q & ":" & _nrAtendimentoJson & "," &
			            Q & "ID_EVENTO_RETORNO_UTI" & Q & ":" & _nrAtendimentoJson & "," &
			            Q & "NM_PACIENTE" & Q & ":" & _nmPacienteJson & "," &
			            Q & "DT_SAIDA_UTI" & Q & ":" & _dtSaidaUtiJson & "," &
			            Q & "DT_ENTRADA_RETORNO_UTI" & Q & ":" & Q & _dtEntradaRetornoUti & Q & "," &
			            Q & "CD_ESTABELECIMENTO" & Q & ":" & _cdEstabelecimentoJson & "," &
			            Q & "CD_SETOR_ATENDIMENTO" & Q & ":" & _cdSetorAtendimentoJson & "," &
			            Q & "CD_MEDICO" & Q & ":" & _cdMedicoJson & "," &
			            Q & "IE_READMISSAO_UTI_48H" & Q & ":" & _ieReadmissaoUti48hJson & "," &
			            Q & "QT_HORAS_ATE_RETORNO_UTI" & Q & ":" & _qtHorasAteRetornoUtiJson & "," &
			            Q & "FAIXA_RISCO_RETORNO_UTI" & Q & ":" & _faixaRiscoRetornoUtiJson & "," &
			            Q & "NIVEL_SEVERIDADE_RETORNO_UTI" & Q & ":" & _nivelSeveridadeRetornoUtiJson &
			            "}",
			        "," // Separador entre objetos.
			    )
			
			// Sempre retorna array JSON valido.
			RETURN
			    IF ( LEN ( _json ) = 0, "[]", "[" & _json & "]" )
		displayFolder: HTML
		lineageTag: f6a7b8c9-d0e1-4f2a-3b4c-5d6e7f8a9b0c

	column placeholder
		lineageTag: 59c06a79-33b7-4e31-894a-1e4202530282
		isNameInferred
		sourceColumn: [placeholder]

	partition _Medidas = calculated
		mode: import
		source = ROW("placeholder", BLANK())

